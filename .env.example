# App
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="Modern E-Commerce Platform"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce_db?schema=public"

# Authentication
JWT_SECRET="change-me-to-a-long-random-secret"
JWT_EXPIRES_IN="7d"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# Email / SendGrid
SENDGRID_API_KEY="SG.your_sendgrid_api_key"
SENDGRID_FROM_EMAIL="no-reply@example.com"
SENDGRID_FROM_NAME="Modern E-Commerce"
SENDGRID_ADMIN_EMAIL="admin@example.com"

# Shipping Provider
SHIPPING_PROVIDER_API_URL="https://api.shipping-provider.example"
SHIPPING_PROVIDER_API_KEY="your_shipping_provider_api_key"

# Optional Storage / Assets
NEXT_PUBLIC_CURRENCY="USD"
NEXT_PUBLIC_DEFAULT_LOCALE="en-US"

# Rate Limiting / Security
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"